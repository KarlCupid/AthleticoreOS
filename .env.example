# Supabase project URL (e.g. https://your-project.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon key
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional aliases used by local/live Supabase integration tests
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-only key for Supabase RLS integration tests. Never expose in app code.
SUPABASE_SERVICE_ROLE_KEY=

# USDA FoodData Central API key for whole-food ingredient search
EXPO_PUBLIC_USDA_API_KEY=

# Support email used by the in-app privacy/support screen
EXPO_PUBLIC_SUPPORT_EMAIL=

# Optional public support page used for App Store metadata and in-app help links
EXPO_PUBLIC_SUPPORT_URL=

# Optional public privacy policy page used for App Store review and in-app links
EXPO_PUBLIC_PRIVACY_POLICY_URL=

# Optional marketing site used in App Store Connect metadata
EXPO_PUBLIC_MARKETING_URL=

# Preview/production crash monitoring
# DSN is safe to expose in Expo public config; keep SENTRY_AUTH_TOKEN server-side in EAS/GitHub only.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_BUILD_PROFILE=development
EXPO_PUBLIC_MONITORING_ENABLED=0
EXPO_PUBLIC_MONITORING_DISABLED=0
EXPO_PUBLIC_MONITORING_TEST_ERROR=0
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Optional workout-programming UI flags
# Dev-only. Beta enables generate -> inspect -> start -> complete -> feedback -> next progression.
# Friend preview and production builds must keep this unset or 0 until content release is productionReady.
EXPO_PUBLIC_WORKOUT_PROGRAMMING_BETA=

# Developer-only read-only preview when beta is disabled.
# Requires a dev build; non-dev builds ignore this even if set.
EXPO_PUBLIC_WORKOUT_PROGRAMMING_PREVIEW=
