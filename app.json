{
  "expo": {
    "name": "AthletiCore OS",
    "slug": "athleticore-os",
    "version": "1.0.0",
    "description": "AthletiCore OS helps combat-sports athletes manage training, recovery, nutrition, hydration, and body-mass and weight-class planning in one guided daily system.",
    "scheme": "athleticore",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.karlcupid.athleticoreos",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#0A0A0A",
      "barStyle": "light-content",
      "translucent": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AthletiCore to scan food barcodes for nutrition lookup.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      "@sentry/react-native/expo"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "60dff959-8e97-4284-a7c7-be0e8c442c00"
      }
    },
    "owner": "karlcupid"
  }
}
