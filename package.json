{
  "name": "athleticore-os",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "typecheck:clean": "tsc --noEmit -p tsconfig.clean.json",
    "test:engine": "node scripts/run-engine-tests.js",
    "test:rls": "node scripts/test-workout-programming-rls.js",
    "test:workout-db": "node scripts/test-workout-programming-db.js",
    "workout:validate-content": "node scripts/validate-workout-programming-content.js",
    "workout:audit-content": "node scripts/audit-workout-programming-content.js",
    "workout:live-db-smoke": "npm run test:workout-db && npm run test:rls",
    "workout:release-gate": "npm run quality && npm run workout:validate-content -- --strict && npm run workout:audit-content -- --release && npm run workout:live-db-smoke",
    "workout:export-seed": "node scripts/export-workout-programming-seed.js",
    "seed:ingredients": "node scripts/generate-ingredient-catalog-seed.js",
    "seed:ingredients:2000": "node scripts/expand-ingredient-catalog.js --target=2000 --migration=020_expand_ingredient_catalog_to_2000.sql",
    "quality": "npm run lint && npm run typecheck && npm run typecheck:clean && npm run test:engine",
    "optimize:images": "node scripts/optimize-images.js"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/outfit": "^0.4.3",
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.15.2",
    "@react-navigation/native": "^7.1.31",
    "@react-navigation/native-stack": "^7.14.3",
    "@shopify/react-native-skia": "2.2.12",
    "@supabase/supabase-js": "^2.98.0",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "victory-native": "^41.20.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "imagemin": "^9.0.1",
    "imagemin-optipng": "^8.0.0",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
